# === Litch's Cortex — Docker 部署环境变量 ===
# 复制此文件为 .env，填入真实值后运行 docker compose up

# ─── 数据库密码 ───────────────────────────────────────────────────────
# MySQL root 密码（内部使用，不对外暴露）
MYSQL_ROOT_PASSWORD=change_me_root_password

# MySQL cortex 用户密码
MYSQL_PASSWORD=change_me_cortex_password

# ─── 认证密钥 ─────────────────────────────────────────────────────────
# JWT 签名密钥，用于用户登录 token。请使用随机字符串，勿泄露。
# 生成命令：openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ─── 管理员账号 ────────────────────────────────────────────────────────
# 首次启动时自动创建的管理员用户名（默认：litch）
DEFAULT_ADMIN_USER=litch

# 首次启动时管理员初始密码。
# 如果不填，系统会自动生成随机密码并打印到 server log（docker compose logs app）。
# 填写后，首次登录后请立即在"修改密码"页面更改。
# DEFAULT_ADMIN_PASSWORD=your_initial_password

# ─── 应用端口 ─────────────────────────────────────────────────────────
# 对外暴露的端口（默认 3000）
PORT=3000

# ─── LLM 配置说明 ─────────────────────────────────────────────────────
# LLM API Key 不在此处配置，而是在应用启动后通过设置页（Settings）配置。
# 支持的 Provider：OpenAI、DeepSeek、OpenRouter、自定义 OpenAI 兼容接口。
#
# ⚠️  重要：LLM 配置是必须的！未配置 LLM Provider，以下功能将无法使用：
#   - 话题提取（PDF 解析后的核心功能）
#   - 摘要生成
#   - 话题探索
#   - 对话交互
#
# 推荐配置：DeepSeek（性价比高）或 OpenRouter（支持多模型切换）
# Embedding 配置同样在设置页配置，未配置时语义搜索不可用。
